# ── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/

# ── Virtual environments ─────────────────────────────────────────────────────
venv/
.venv/
env/
ENV/

# ── Test / tooling caches ────────────────────────────────────────────────────
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# ── PyInstaller / Inno Setup build output ────────────────────────────────────
build/
dist/
*.manifest
build_log.txt
Output/
*.exe

# ── Secrets & local user data (NEVER commit) ─────────────────────────────────
# Runtime config lives in %APPDATA%\YancoRead\userdata.json, but guard against
# any copy landing inside the repo tree. API keys / tokens belong here only.
userdata.json
*.userdata.json
.env
.env.*
*.key
secrets.*

# ── Bundled extractor binaries (drop-ins, not source) ────────────────────────
assets/tools/*.exe
assets/tools/*.dll

# ── Claude Code: share team config, ignore personal/local bits ───────────────
# settings.json + hooks/ + CLAUDE.md are intentionally tracked (team-shared);
# only machine-local / personal files are ignored.
.claude/*
!.claude/settings.json
!.claude/hooks/
.claude/settings.local.json
.claude/launch.json

# ── Editor / OS noise ────────────────────────────────────────────────────────
.idea/
.vscode/
.DS_Store
Thumbs.db
*.tmp
*.bak
*.log

# ── Source-archive artifacts (built into root, not tracked) ──
*.zip
